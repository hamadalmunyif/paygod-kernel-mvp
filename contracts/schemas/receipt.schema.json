{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paygod/receipt.schema.json",
  "title": "PayGod Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "spec_version",
    "clock",
    "canonicalization",
    "runner",
    "pack",
    "input",
    "bundle",
    "verdict",
    "replay"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "paygod/v1"
    },
    "kind": {
      "type": "string",
      "const": "Receipt"
    },

    "spec_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "generated_at": {
      "type": "string",
      "description": "Optional. If present, MUST equal the injected deterministic clock value (PAYGOD_CLOCK), not wall time."
    },

    "clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "string" },
        "source": { "type": "string", "enum": ["env:PAYGOD_CLOCK"] }
      }
    },

    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json", "schema_manifest_sha256"],
      "properties": {
        "json": { "type": "string", "enum": ["rfc8785"] },
        "schema_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "image_digest"],
      "properties": {
        "image": { "type": "string" },
        "image_digest": { "type": "string" }
      }
    },

    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "path", "digest_sha256"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "path": { "type": "string" },
        "digest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_hash"],
      "properties": {
        "canonical_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_digest", "manifest_sha256", "files"],
      "properties": {
        "bundle_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "sha256", "bytes"],
            "properties": {
              "name": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "bytes": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },

    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "rule_name", "reason"],
      "properties": {
        "value": { "type": "string", "enum": ["allow", "deny", "error"] },
        "rule_name": { "type": "string" },
        "reason": { "type": "string" }
      }
    },

    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": { "type": "string" }
      }
    }
  }
}